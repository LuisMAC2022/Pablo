# Este archivo es solo una plantilla: no debe contener valores reales.
# Mantén el archivo .env fuera del control de versiones y define ahí los secretos locales.
APP_NAME=Pablo
DEBUG=false
DATABASE_URL=postgresql://<usuario>:<password>@<host>:<puerto>/<database>?client_encoding=utf8
JWT_SECRET_KEY=<generar-con-openssl-rand-hex-32>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
VISITANTES_SHEET_ID=<id-de-google-sheet-visitantes>
PASSWORD_TEMPORAL_BIOLOGOS=<definir-solo-en-entorno-seguro>
GOOGLE_CREDENTIALS_PATH=<ruta-a-credenciales-google-json>
